# LLM (DashScope 代理 deepseek-v4-pro)
LLM_API_KEY=
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v4-pro

# Embedding (本地 Ollama bge-m3)
EMBEDDING_API_KEY=ollama
EMBEDDING_API_BASE=http://localhost:11434/v1
EMBEDDING_MODEL=bge-m3

# Evaluation (RAGAS, DeepSeek 官方 API)
EVAL_JUDGE_MODEL=deepseek-v4-flash
EVAL_JUDGE_API_BASE=https://api.deepseek.com/v1
EVAL_JUDGE_API_KEY=
EVAL_ANSWER_MODEL=deepseek-v4-flash
EVAL_ANSWER_API_BASE=https://api.deepseek.com/v1
EVAL_ANSWER_API_KEY=

# Neo4j (知识图谱)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ChromaDB & Knowledge
CHROMA_PERSIST_DIR=./chroma_db
KNOWLEDGE_DIR=./knowledge

# Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Auth (REQUIRED: must override in .env, do NOT use the example value in production)
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET
