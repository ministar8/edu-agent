# ═══════════════════════════════════════════════════════════════
# EDU-AGENT 配置模板 — 复制为 .env 后根据实际情况修改
# ═══════════════════════════════════════════════════════════════

# ── LLM (OpenAI 兼容接口，DashScope 代理 / DeepSeek 官方) ──────
LLM_API_KEY=
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-max
LLM_MODEL_FAST=qwen3.6-27b

# ── Embedding (本地 TEI bge-m3) ───────────────────
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=http://localhost:11435
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── Reranker (本地 TEI bge-reranker-v2-m3) ──────
RERANK_ENABLED=true
RERANK_MODE=local
RERANK_LOCAL_URL=http://localhost:8080
RERANK_MIN_SCORE=0.3
RERANK_ABSOLUTE_MIN_SCORE=0.15

# ── HyDE (假设文档嵌入) ──────────────────────────
HYDE_ENABLED=true
HYDE_MIN_DOCS=2
HYDE_RERANK_SCORE_THRESHOLD=0.25
HYDE_MAX_CHARS=500

# ── Semantic Cache (ChromaDB-backed) ──────────────
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.88

# ── Evaluation (RAGAS) ──────────────────────────
EVAL_JUDGE_MODEL=qwen3.6-plus
EVAL_JUDGE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_JUDGE_API_KEY=
EVAL_ANSWER_MODEL=qwen3.7-plus
EVAL_ANSWER_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_ANSWER_API_KEY=

# ── Token Budget ────────────────────────────────
CONTEXT_TOKEN_BUDGET=6000
CONTEXT_TOKEN_BUDGET_SHALLOW=3000
CONTEXT_TOKEN_BUDGET_DEEP=8000
MAX_STUDENT_PROFILE_TOKENS=500

# ── Agent Timeout (seconds) ──────────────────────
GLOBAL_DEADLINE=150
LLM_TIMEOUT=90
ROUTER_TIMEOUT=8
AGENT_PRIMARY_TIMEOUT=90
AGENT_RETRY_TIMEOUT=45
RAG_FALLBACK_TIMEOUT=30
PRE_RETRIEVAL_TIMEOUT=30
TOOL_CALL_TIMEOUT=30
STREAM_TIMEOUT=120
QUESTION_GEN_TIMEOUT=120
EMBEDDING_TIMEOUT=60
RERANK_TIMEOUT=30
DECOMPOSE_TIMEOUT=10

# ── Agent Temperature ──────────────────────────
TEMP_PRECISE=0.0
TEMP_CREATIVE=0.3
TEMP_DEFAULT=0.3
TEMP_SYNTHESIS=0.15

# ── ChromaDB ─────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8100

# ── Neo4j (知识图谱) ──────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Server ─────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=false
CORS_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1

# ── Knowledge ──────────────────────────────────
KNOWLEDGE_DIR=./knowledge

# ── Auth (REQUIRED: must override in .env, do NOT use the example value in production) ──
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
